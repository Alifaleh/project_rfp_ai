<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================== 
             PHASE 1: INITIALIZATION (Scope and Constraints) 
             ============================================== -->

        <!-- 0. Contact Information -->
        <record id="field_init_contact_name" model="rfp.custom.field">
            <field name="name">Contact Person Name</field>
            <field name="code">contact_name</field>
            <field name="phase">init</field>
            <field name="input_type">text_input</field>
            <field name="sequence">0</field>
            <field name="is_required">True</field>
            <field name="placeholder">e.g. John Doe</field>
        </record>
        <record id="field_init_contact_email" model="rfp.custom.field">
            <field name="name">Contact Email</field>
            <field name="code">contact_email</field>
            <field name="phase">init</field>
            <field name="input_type">text_input</field>
            <field name="sequence">0</field>
            <field name="is_required">True</field>
            <field name="placeholder">e.g. john@example.com</field>
        </record>
         <record id="field_init_contact_phone" model="rfp.custom.field">
            <field name="name">Contact Phone</field>
            <field name="code">contact_phone</field>
            <field name="phase">init</field>
            <field name="input_type">text_input</field>
            <field name="sequence">0</field>
            <field name="is_required">True</field>
            <field name="placeholder">e.g. +1 555 0199</field>
        </record>
        <record id="field_init_contact_details" model="rfp.custom.field">
            <field name="name">Other Contact Details</field>
            <field name="code">contact_details</field>
            <field name="phase">init</field>
            <field name="input_type">textarea</field>
            <field name="sequence">0</field>
            <field name="is_required">False</field>
            <field name="placeholder">Address, Availability, etc.</field>
        </record>

        <!-- 1. Project Type (Dropdown with extensive options) -->
        <record id="field_init_project_type" model="rfp.custom.field">
            <field name="name">Project Type</field>
            <field name="code">project_type</field>
            <field name="phase">init</field>
            <field name="input_type">select</field>
            <field name="sequence">1</field>
            <field name="help_text">What category best describes this project?</field>
            <field name="specify_triggers">["other"]</field>
            <field name="is_required">True</field>
        </record>
        
        <!-- Standard Software & IT -->
        <record id="opt_init_pt_sw_web" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">software_web</field>
            <field name="label">Custom Web Application</field>
            <field name="group_name">Software &amp; IT</field>
            <field name="sequence">10</field>
        </record>
        <record id="opt_init_pt_sw_mobile" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">software_mobile</field>
            <field name="label">Mobile App (iOS/Android)</field>
            <field name="group_name">Software &amp; IT</field>
            <field name="sequence">11</field>
        </record>
        <record id="opt_init_pt_sw_saas" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">software_saas</field>
            <field name="label">SaaS / Cloud Product</field>
            <field name="group_name">Software &amp; IT</field>
            <field name="sequence">12</field>
        </record>
        
        <!-- Healthcare -->
        <record id="opt_init_pt_health_emr" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">health_emr</field>
            <field name="label">EMR / Hospital Management System</field>
            <field name="group_name">Healthcare</field>
            <field name="sequence">20</field>
        </record>
        <record id="opt_init_pt_health_telemed" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">health_telemedicine</field>
            <field name="label">Telemedicine Platform</field>
            <field name="group_name">Healthcare</field>
            <field name="sequence">21</field>
        </record>
        <record id="opt_init_pt_health_pharmacy" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">health_pharmacy</field>
            <field name="label">Pharmacy Inventory / Supply Chain</field>
            <field name="group_name">Healthcare</field>
            <field name="sequence">22</field>
        </record>
        
        <!-- Oil & Gas / Energy -->
        <record id="opt_init_pt_oil_exploration" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">oil_gas_exploration</field>
            <field name="label">Exploration / Drilling Workflow</field>
            <field name="group_name">Oil, Gas &amp; Energy</field>
            <field name="sequence">30</field>
        </record>
        <record id="opt_init_pt_oil_refining" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">oil_gas_refining</field>
            <field name="label">Refining / Downstream Management</field>
            <field name="group_name">Oil, Gas &amp; Energy</field>
            <field name="sequence">31</field>
        </record>
        <record id="opt_init_pt_energy_solar" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">energy_renewable</field>
            <field name="label">Renewable / Solar Farm Monitoring</field>
            <field name="group_name">Oil, Gas &amp; Energy</field>
            <field name="sequence">32</field>
        </record>
        <record id="opt_init_pt_power_grid" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">energy_grid_mgmt</field>
            <field name="label">Smart Grid / Utility Management</field>
            <field name="group_name">Oil, Gas &amp; Energy</field>
            <field name="sequence">33</field>
        </record>
        
        <!-- Construction / Real Estate -->
        <record id="opt_init_pt_const_mgmt" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">const_mgmt</field>
            <field name="label">Project Management / BIM</field>
            <field name="group_name">Construction &amp; Real Estate</field>
            <field name="sequence">40</field>
        </record>
        <record id="opt_init_pt_const_real_estate" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">const_real_estate</field>
            <field name="label">Real Estate Development Platform</field>
            <field name="group_name">Construction &amp; Real Estate</field>
            <field name="sequence">41</field>
        </record>
        <record id="opt_init_pt_const_smart_city" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">const_smart_city</field>
            <field name="label">Smart City / IoT Infrastructure</field>
            <field name="group_name">Construction &amp; Real Estate</field>
            <field name="sequence">42</field>
        </record>
        
        <!-- Finance / Fintech -->
        <record id="opt_init_pt_fin_banking" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">finance_banking</field>
            <field name="label">Digital Banking / Core Banking</field>
            <field name="group_name">Finance &amp; Fintech</field>
            <field name="sequence">50</field>
        </record>
        <record id="opt_init_pt_fin_payment" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">finance_payments</field>
            <field name="label">Payment Gateway / Wallet Solution</field>
            <field name="group_name">Finance &amp; Fintech</field>
            <field name="sequence">51</field>
        </record>
        <record id="opt_init_pt_fin_trading" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">finance_trading</field>
            <field name="label">Stock Trading / Asset Management</field>
            <field name="group_name">Finance &amp; Fintech</field>
            <field name="sequence">52</field>
        </record>
        
        <!-- Logistics & Transport -->
        <record id="opt_init_pt_log_fleet" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">logistics_fleet</field>
            <field name="label">Fleet Management / Tracking</field>
            <field name="group_name">Logistics &amp; Transport</field>
            <field name="sequence">60</field>
        </record>
        <record id="opt_init_pt_log_warehouse" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">logistics_warehouse</field>
            <field name="label">Warehouse Management (WMS)</field>
            <field name="group_name">Logistics &amp; Transport</field>
            <field name="sequence">61</field>
        </record>
        <record id="opt_init_pt_log_shipping" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">logistics_shipping</field>
            <field name="label">Global Shipping / Freight Forwarding</field>
            <field name="group_name">Logistics &amp; Transport</field>
            <field name="sequence">62</field>
        </record>
        
        <!-- Retail & Hospitality -->
        <record id="opt_init_pt_retail_pos" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">retail_pos</field>
            <field name="label">POS System / Inventory Sync</field>
            <field name="group_name">Retail &amp; Hospitality</field>
            <field name="sequence">70</field>
        </record>
        <record id="opt_init_pt_hotel_mgmt" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">hospitality_hotel</field>
            <field name="label">Hotel / Resort Management System</field>
            <field name="group_name">Retail &amp; Hospitality</field>
            <field name="sequence">71</field>
        </record>
        
        <!-- Government & Public Sector -->
        <record id="opt_init_pt_gov_portal" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">gov_e_service</field>
            <field name="label">E-Government Citizen Portal</field>
            <field name="group_name">Government</field>
            <field name="sequence">80</field>
        </record>
        <record id="opt_init_pt_gov_identity" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">gov_id_mgmt</field>
            <field name="label">National Identity / KYC Management</field>
            <field name="group_name">Government</field>
            <field name="sequence">81</field>
        </record>

        <!-- Education & EdTech -->
        <record id="opt_init_pt_edu_lms" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">edu_lms</field>
            <field name="label">Learning Management System (LMS)</field>
            <field name="group_name">Education</field>
            <field name="sequence">90</field>
        </record>
        
        <!-- Manufacturing -->
        <record id="opt_init_pt_mfg_erp" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">mfg_erp_integration</field>
            <field name="label">Factory ERP / Supply Chain</field>
            <field name="group_name">Manufacturing</field>
            <field name="sequence">100</field>
        </record>
        <record id="opt_init_pt_mfg_scada" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">mfg_scada</field>
            <field name="label">SCADA / Industrial Control Systems</field>
            <field name="group_name">Manufacturing</field>
            <field name="sequence">101</field>
        </record>

        <!-- Generic Nature -->
        <record id="opt_init_pt_greenfield" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">greenfield</field>
            <field name="label">New Application (Greenfield)</field>
            <field name="group_name">Generic / Nature of Project</field>
            <field name="sequence">200</field>
        </record>
        <record id="opt_init_pt_rewrite" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">legacy_rewrite</field>
            <field name="label">Rewrite Legacy System</field>
            <field name="group_name">Generic / Nature of Project</field>
            <field name="sequence">201</field>
        </record>

        <record id="opt_init_pt_other" model="rfp.field.option">
            <field name="field_id" ref="field_init_project_type"/>
            <field name="value">other</field>
            <field name="label">Other (Please Specify)</field>
            <field name="sequence">999</field>
        </record>

        <!-- 2. Target Audience (Text + Extensive Suggestions) -->
        <record id="field_init_audience" model="rfp.custom.field">
            <field name="name">Target Audience</field>
            <field name="code">target_audience</field>
            <field name="phase">init</field>
            <field name="input_type">text_input</field>
            <field name="sequence">2</field>
            <field name="placeholder">Who will use this system? Be specific.</field>
            <field name="is_required">True</field>
        </record>
        <record id="sugg_init_aud_b2b" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_audience"/>
            <field name="name">B2B Enterprise Customers</field>
        </record>
        <record id="sugg_init_aud_b2c" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_audience"/>
            <field name="name">Public B2C Consumers</field>
        </record>
        <record id="sugg_init_aud_internal" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_audience"/>
            <field name="name">Internal Employees (Intranet)</field>
        </record>
         <record id="sugg_init_aud_admins" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_audience"/>
            <field name="name">System Administrators Only</field>
        </record>
         <record id="sugg_init_aud_partners" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_audience"/>
            <field name="name">External Partners / Vendors</field>
        </record>

        <!-- 3. Budget Range (Text + Suggestions) -->
        <!-- Changed from Select to Text per request for flexibility -->
        <record id="field_init_budget" model="rfp.custom.field">
            <field name="name">Estimated Budget</field>
            <field name="code">budget_range</field>
            <field name="phase">init</field>
            <field name="input_type">text_input</field>
            <field name="sequence">3</field>
            <field name="placeholder">e.g. $50,000 or "Strategic Tier"</field>
            <field name="is_required">True</field>
        </record>
        <record id="sugg_init_budget_vlow" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_budget"/>
            <field name="name">Under $25,000 (Small/Pilot)</field>
        </record>
        <record id="sugg_init_budget_low" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_budget"/>
            <field name="name">$25,000 - $75,000 (Standard Mid-Market)</field>
        </record>
        <record id="sugg_init_budget_med" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_budget"/>
            <field name="name">$75,000 - $200,000 (Enterprise/Full-Scale)</field>
        </record>
        <record id="sugg_init_budget_high" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_budget"/>
            <field name="name">$200,000 - $500,000 (Large Transformation)</field>
        </record>
        <record id="sugg_init_budget_ent" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_budget"/>
            <field name="name">Over $500,000 (Strategic Investment)</field>
        </record>
        <record id="sugg_init_budget_tbd" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_budget"/>
            <field name="name">Budget is not yet defined (TBD)</field>
        </record>

        <!-- 4. Success Goal (TextArea + Suggestions) -->
        <record id="field_init_goal" model="rfp.custom.field">
            <field name="name">Primary Success Metric</field>
            <field name="code">primary_goal</field>
            <field name="phase">init</field>
            <field name="input_type">textarea</field>
            <field name="sequence">4</field>
            <field name="placeholder">What does success look like? (ROI, Efficiency, etc.)</field>
            <field name="is_required">True</field>
        </record>
         <record id="sugg_init_goal_rev" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_goal"/>
            <field name="name">Increase Revenue by 20%</field>
        </record>
        <record id="sugg_init_goal_eff" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_goal"/>
            <field name="name">Improve Operational Efficiency (Time Saving)</field>
        </record>
        <record id="sugg_init_goal_usr" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_goal"/>
            <field name="name">Improve User Experience / Satisfaction</field>
        </record>
        <record id="sugg_init_goal_mod" model="rfp.field.suggestion">
            <field name="field_id" ref="field_init_goal"/>
            <field name="name">Modernize Tech Stack (Reduce Tech Debt)</field>
        </record>
        


        <!-- ==============================================
             PHASE 2: POST ANALYSIS (Technical Specifics)
             ============================================== -->

        <!-- 1. Hosting (Radio + Other) -->
        <record id="field_post_hosting" model="rfp.custom.field">
            <field name="name">Hosting Preference</field>
            <field name="code">hosting_preference</field>
            <field name="phase">post_gathering</field>
            <field name="input_type">radio</field>
            <field name="sequence">1</field>
            <field name="specify_triggers">["other"]</field>
            <field name="is_required">True</field>
        </record>
        <record id="opt_post_host_cloud" model="rfp.field.option">
            <field name="field_id" ref="field_post_hosting"/>
            <field name="value">cloud</field>
            <field name="label">Cloud (AWS/GCP/Azure)</field>
        </record>
        <record id="opt_post_host_prem" model="rfp.field.option">
            <field name="field_id" ref="field_post_hosting"/>
            <field name="value">on_premise</field>
            <field name="label">On-Premise / Private Server</field>
        </record>
        <record id="opt_post_host_hybrid" model="rfp.field.option">
            <field name="field_id" ref="field_post_hosting"/>
            <field name="value">hybrid</field>
            <field name="label">Hybrid</field>
        </record>
        <record id="opt_post_host_other" model="rfp.field.option">
            <field name="field_id" ref="field_post_hosting"/>
            <field name="value">other</field>
            <field name="label">Other (Please Specify)</field>
        </record>

        <!-- 2. Compliance (TextArea + Suggestions) -->
        <!-- Changed from Checkboxes to TextArea per request for better flexibility -->
        <record id="field_post_compliance" model="rfp.custom.field">
            <field name="name">Compliance Requirements</field>
            <field name="code">compliance_reqs</field>
            <field name="phase">post_gathering</field>
            <field name="input_type">textarea</field>
            <field name="sequence">2</field>
            <field name="placeholder">List all regulatory compliance needs (or select suggestions)</field>
            <field name="is_required">True</field>
        </record>
        <record id="sugg_post_comp_gdpr" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_compliance"/>
            <field name="name">GDPR (EU Data Protection)</field>
        </record>
         <record id="sugg_post_comp_ccpa" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_compliance"/>
            <field name="name">CCPA (California Privacy)</field>
        </record>
        <record id="sugg_post_comp_hipaa" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_compliance"/>
            <field name="name">HIPAA (Health Data)</field>
        </record>
        <record id="sugg_post_comp_soc2" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_compliance"/>
            <field name="name">SOC2 Type II</field>
        </record>
         <record id="sugg_post_comp_pci" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_compliance"/>
            <field name="name">PCI DSS (Payment Security)</field>
        </record>
         <record id="sugg_post_comp_none" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_compliance"/>
            <field name="name">No specific compliance requirements</field>
        </record>

        <!-- 3. Scale (Text + Suggestions) -->
         <!-- Changed from Select to Text -->
        <record id="field_post_scale" model="rfp.custom.field">
            <field name="name">Expected User Load (Concurrent)</field>
            <field name="code">user_load_scale</field>
            <field name="phase">post_gathering</field>
            <field name="input_type">text_input</field>
            <field name="sequence">3</field>
            <field name="placeholder">e.g. 100 users, or "Mass Scale"</field>
            <field name="is_required">True</field>
        </record>
        <record id="sugg_post_scale_low" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_scale"/>
            <field name="name">&lt; 100 Concurrent Users</field>
        </record>
        <record id="sugg_post_scale_med" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_scale"/>
            <field name="name">100 - 1,000 Concurrent Users</field>
        </record>
        <record id="sugg_post_scale_high" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_scale"/>
            <field name="name">1,000+ Concurrent Users</field>
        </record>

         <!-- 4. Integrations (TextArea + Suggestions) -->
        <record id="field_post_integrations" model="rfp.custom.field">
            <field name="name">Mandatory Integrations</field>
            <field name="code">tech_integrations</field>
            <field name="phase">post_gathering</field>
            <field name="input_type">textarea</field>
            <field name="sequence">4</field>
            <field name="placeholder">List systems to integrate...</field>
            <field name="is_required">True</field>
        </record>
         <record id="sugg_post_int_salesforce" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_integrations"/>
            <field name="name">Salesforce CRM</field>
        </record>
        <record id="sugg_post_int_sap" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_integrations"/>
            <field name="name">SAP / Oracle ERP</field>
        </record>
        <record id="sugg_post_int_stripe" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_integrations"/>
            <field name="name">Stripe / PayPal (Payments)</field>
        </record>
        <record id="sugg_post_int_auth" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_integrations"/>
            <field name="name">Auth0 / Okta (SSO)</field>
        </record>
         <record id="sugg_post_int_none" model="rfp.field.suggestion">
            <field name="field_id" ref="field_post_integrations"/>
            <field name="name">No external integrations required</field>
        </record>
    </data>
</odoo>
